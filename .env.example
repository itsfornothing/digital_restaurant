# ============================================================================
# Restaurant Platform — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ============================================================================

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.development

# Comma-separated list of allowed host/domain names (production)
ALLOWED_HOSTS=platform.example.com,*.platform.example.com

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
DB_NAME=restaurant_platform
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# ---------------------------------------------------------------------------
# PostgreSQL Read Replica (Task 20.4 — Requirement 19.9)
# Configure these to route read-heavy queries (Income, ProfitRecord,
# Expense, AuditLog) to a PostgreSQL read replica for analytics/reporting.
# If omitted, the router falls back to the primary database gracefully.
# ---------------------------------------------------------------------------
REPLICA_DB_NAME=restaurant_platform
REPLICA_DB_USER=postgres
REPLICA_DB_PASSWORD=postgres
REPLICA_DB_HOST=db-replica
REPLICA_DB_PORT=5432

# ---------------------------------------------------------------------------
# Cloudflare R2 object storage
# ---------------------------------------------------------------------------
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<YOUR_R2_ACCESS_KEY_ID>
R2_SECRET_ACCESS_KEY=<YOUR_R2_SECRET_ACCESS_KEY>
R2_BUCKET_NAME=restaurant-platform
# Optional: public custom domain for serving R2 assets
R2_CUSTOM_DOMAIN=https://assets.example.com

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=<YOUR_SENDGRID_API_KEY>
DEFAULT_FROM_EMAIL=noreply@example.com

# ---------------------------------------------------------------------------
# Staging / smoke test
# ---------------------------------------------------------------------------
STAGING_URL=https://staging.platform.example.com

# ---------------------------------------------------------------------------
# Docker / deployment (set by CI/CD pipeline)
# ---------------------------------------------------------------------------
DOCKER_IMAGE_TAG=latest
